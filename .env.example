# Frontend local/hosted routing
# Public frontend build-time API base, for example http://127.0.0.1:8787
VITE_API_BASE_URL=

# Hosted same-origin edge proxy target used by middleware.ts
MEDLIFE_BACKEND_URL=

# Shared secret optionally attached by middleware.ts when proxying to the backend.
BACKEND_SHARED_SECRET=

# Backend AI debrief / triage
# Optional. If missing, debrief falls back to rule-based assessment.
ANTHROPIC_API_KEY=

# Backend EHR demo endpoint
# Optional. Enables the fake credential-vault EHR lookup demo.
EHR_API_TOKEN=

# Optional LiveKit voice backend
# These are only needed if you want to mint voice room tokens.
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Optional voice-worker providers
DEEPGRAM_API_KEY=
CARTESIA_API_KEY=

# Frontend local/hosted routing
# Public frontend build-time API base, for example http://127.0.0.1:8787
VITE_API_BASE_URL=

# Hosted same-origin edge proxy target used by middleware.ts
MEDLIFE_BACKEND_URL=

# Shared secret optionally attached by middleware.ts when proxying to the backend.
BACKEND_SHARED_SECRET=

# Backend persistence and cookie security
# Optional SQLite path for local development and isolated tests.
MEDLIFE_DB_PATH=
# Set to 1 when serving the backend over HTTPS so auth cookies are marked Secure.
MEDLIFE_COOKIE_SECURE=
# Set to production to fail fast on obviously unsafe cookie/origin settings.
MEDLIFE_ENV=
# Comma-separated allowed frontend origins for cookie-backed browser access.
MEDLIFE_CORS_ORIGINS=
# Optional security tuning for accounts and sessions.
MEDLIFE_PASSWORD_PBKDF2_ITERATIONS=
MEDLIFE_SESSION_ABSOLUTE_HOURS=
MEDLIFE_SESSION_IDLE_MINUTES=
MEDLIFE_MAX_ACTIVE_SESSIONS=
MEDLIFE_MAX_EVENT_PAYLOAD_BYTES=
MEDLIFE_LOGIN_FAILURE_LIMIT=
MEDLIFE_LOGIN_FAILURE_WINDOW_MINUTES=

# Backend AI debrief / triage
# Optional. If missing, debrief falls back to rule-based assessment.
ANTHROPIC_API_KEY=

# Optional text AI patient mode
# Set to 1 to expose learner-facing text AI patient mode when the backend also has provider access.
MEDLIFE_TEXT_AI_PATIENT_ENABLED=
# Optional model name for the text AI patient endpoint.
MEDLIFE_TEXT_AI_PATIENT_MODEL=

# Backend EHR demo endpoint
# Optional. Enables the fake credential-vault EHR lookup demo.
EHR_API_TOKEN=

# Optional LiveKit voice backend
# These are only needed if you want to mint voice room tokens.
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Optional voice-worker providers
DEEPGRAM_API_KEY=
CARTESIA_API_KEY=
